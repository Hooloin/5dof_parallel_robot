'===========================================================
' ZMC406-V2控制器EtherCAT控制5台EC1步进驱动器调试程序
' 功能：初始化EtherCAT总线，配置5个轴，执行简单运动测试
'===========================================================

'-----------------------------------------------------------
' 1. EtherCAT总线初始化
'-----------------------------------------------------------
DIM slot, node_count, i

slot = 0  'EtherCAT总线槽位号为0

' 扫描EtherCAT总线节点
BUSRESET(slot)
DWELL(2000)  '等待2秒让总线初始化

' 检查总线节点数
node_count = NODE_COUNT(slot)
PRINT "检测到EtherCAT节点数: ", node_count

' 等待总线就绪
i = 0
WHILE BUS_STATE(slot) <> 8 AND i < 100
    DWELL(100)
    i = i + 1
WEND

IF BUS_STATE(slot) = 8 THEN
    PRINT "EtherCAT总线初始化成功"
ELSE
    PRINT "EtherCAT总线初始化失败，状态:", BUS_STATE(slot)
    END
ENDIF

'-----------------------------------------------------------
' 2. 轴映射配置（映射5个EtherCAT驱动器到轴0-4）
'-----------------------------------------------------------
' 轴映射语法: AXIS_ADDRESS(轴号) = (槽位号<<16) + 驱动器编号 + 1
' EtherCAT驱动器编号从0开始

PRINT "开始轴映射..."

' 先将轴设为虚拟轴
BASE(0, 1, 2, 3, 4)
ATYPE = 0, 0, 0, 0, 0

' 映射5个EtherCAT轴
AXIS_ADDRESS(0) = (0<<16) + 0 + 1  '第1个驱动器映射到轴0
AXIS_ADDRESS(1) = (0<<16) + 1 + 1  '第2个驱动器映射到轴1
AXIS_ADDRESS(2) = (0<<16) + 2 + 1  '第3个驱动器映射到轴2
AXIS_ADDRESS(3) = (0<<16) + 3 + 1  '第4个驱动器映射到轴3
AXIS_ADDRESS(4) = (0<<16) + 4 + 1  '第5个驱动器映射到轴4

PRINT "轴映射完成"

'-----------------------------------------------------------
' 3. 轴参数配置
'-----------------------------------------------------------
PRINT "开始配置轴参数..."

BASE(0, 1, 2, 3, 4)  '选择轴0-4

' 设置轴类型（EtherCAT总线轴类型）
' 根据EC1驱动器，使用总线脉冲方向模式
ATYPE = 4, 4, 4, 4, 4  '4=总线脉冲+方向模式

' 设置脉冲当量（每转脉冲数）
' EC1-570默认细分为1600，根据实际需求调整
UNITS = 1600, 1600, 1600, 1600, 1600

' 设置运动速度（单位：UNITS/秒）
SPEED = 10, 10, 10, 10, 10  '10转/秒

' 设置加速度（单位：UNITS/秒2）
ACCEL = 100, 100, 100, 100, 100  '100转/秒2

' 设置减速度（单位：UNITS/秒2）
DECEL = 100, 100, 100, 100, 100

' 设置S曲线时间（毫秒）
SRAMP = 50, 50, 50, 50, 50

' 禁用软限位（调试时）
FSEE_LIMIT = 20000000, 20000000, 20000000, 20000000, 20000000
RS_LIMIT = -20000000, -20000000, -20000000, -20000000, -20000000

' 配置限位和原点信号（根据实际接线调整）
' -1表示禁用
FWD_IN = -1, -1, -1, -1, -1  '正向限位
REV_IN = -1, -1, -1, -1, -1  '负向限位
DATUM_IN = -1, -1, -1, -1, -1  '原点信号

PRINT "轴参数配置完成"

' 等待配置生效
DWELL(500)

'-----------------------------------------------------------
' 4. 使能驱动器
'-----------------------------------------------------------
PRINT "使能驱动器..."

BASE(0, 1, 2, 3, 4)
WDOG = 1000  '设置看门狗时间
DRIVE_ON  '使能所有轴

DWELL(500)  '等待使能生效

' 检查轴状态
FOR i = 0 TO 4
    BASE(i)
    IF AXISSTATUS = "On" THEN
        PRINT "轴", i, "使能成功"
    ELSE
        PRINT "轴", i, "使能失败，状态:", AXISSTATUS
    ENDIF
NEXT i

PRINT "驱动器使能完成"
PRINT "========================================="
PRINT "初始化完成！可以开始运动测试"
PRINT "========================================="

